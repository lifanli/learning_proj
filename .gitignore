# Git Ignore for Learning Agent System Project

# OpenClaw internal directories
.openclaw/
.agents/
.cache/
.local/
.mc/

# Auth and credentials
*.token
auth-profiles.json
*.key
*.secret

# Environment files
.env
.env.local
.env.*.local

# IDE and editors
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# Node modules (if any)
node_modules/

# Python virtual environments
venv/
.env/
__pycache__/
*.pyc

# Build outputs
dist/
build/
*.egg-info/

# Large files (>100MB)
*.iso
*.zip
*.tar.gz
*.bak

# MinIO config
mc/
